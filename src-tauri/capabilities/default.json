{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "https://quotes-and-sales-tracker.vercel.app/**",
      "http://localhost:3000/**"
    ]
  },
  "permissions": [
    "core:default",
    "allow-save-file",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
