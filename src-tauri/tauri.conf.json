{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quotes",
  "version": "1.4.1",
  "identifier": "com.quotes.salestracker",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quotes",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg",
      "app"
    ],
    "publisher": "Kamrul Islam, IT Officer, B&F Corporate",
    "copyright": "Apps Developed by Kamrul Islam, IT Officer, B&F Corporate",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/kamrulislam2/quotes-and-sales-tracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0REU3NEFGMDFDQUQ2REMKUldUYzFzb0JyM1RlMUgvcHduM3hXMUlackRGMmR4amJIWkZkY2h5VDBoL1p1RzNVMkRwSWdFN0MK"
    }
  }
}
